    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "uuid": "^14.0.0",
    "vite": "^6.2.0",
    "wrangler": "^4.85.0"
  }
