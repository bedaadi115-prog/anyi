  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config client/vite.config.ts client",
    "build": "vite build --config client/vite.config.ts client",
    "preview": "vite preview --config client/vite.config.ts client",
    "clean": "rimraf client/dist",
    "lint": "tsc --project client/tsconfig.json --noEmit",
    "deploy": "cd server && wrangler pages deploy",
    "dev:server": "cd server && wrangler pages dev ../client/dist"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
